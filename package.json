{
  "name": "medical-pdf-parser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "국민건강보험공단 진료내역 PDF 3종 결정론적 좌표 파서 (브라우저 전용, 서버 없음)",
  "scripts": {
